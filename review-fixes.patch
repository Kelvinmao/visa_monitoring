+// releaseLocation pins the release time to JST. The target server
+// (toronto.rsvsys.jp) operates in Asia/Tokyo, so ReleaseHour/Minute are
+// always interpreted as JST regardless of the host's local timezone.
+func releaseLocation() *time.Location {
+        loc, err := time.LoadLocation("Asia/Tokyo")
+        if err != nil {
+                // Fallback: fixed +09:00 if tzdata is unavailable on the host.
+                return time.FixedZone("JST", 9*3600)
+        }
+        return loc
+}
